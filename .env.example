# Recommended: keep your token in ~/.env and start with:
#   docker compose --env-file ~/.env up --build
#
# Or copy this file to .env in the project root.

# GitHub auth. Classic token needs the `repo` scope to read PRIVATE repos; a
# fine-grained token needs read access to repository metadata.
# Optional: if left blank and you've run `gh auth login`, the dashboard falls
# back to `gh auth token` automatically (no PAT needed).
GITHUB_TOKEN=ghp_your_token_here

# Optional. The owners (users and/or organisations) to load repositories from.
# Accepts a comma-separated list OR a JSON array. Leave blank to load YOUR own
# full repo set (public + private + archived).
#
#   - Your own login         -> all your repos (private included)
#   - An org you belong to   -> the org's repos (private included)
#   - Any other user/org     -> public repos only (a warning is shown on screen)
#
# Examples:
#   GITHUB_OWNERS=davidsneighbour, dnbhq, gohugo-ananke
#   GITHUB_OWNERS=["davidsneighbour","dnbhq","gohugo-ananke"]
GITHUB_OWNERS=

# Sync behaviour
# Fetch repos from GitHub on server startup (true/false, default: true)
SYNC_ON_STARTUP=true
# Automatically re-sync on a schedule (true/false, default: true)
SYNC_AUTO=true
# How often to auto-sync in minutes (default: 60, minimum: 1)
SYNC_INTERVAL_MINUTES=60

# Age in days when a repository becomes due in "Today" again.
# The board shows Today + (DEFAULT_INACTIVITY_DAYS - 1) future day columns.
# Can be overridden per repository in the UI.
DEFAULT_INACTIVITY_DAYS=7

{
  "name": "@davidsneighbour/project-dashboard",
  "version": "0.1.0",
  "description": "A local-only dashboard that lists **all** your GitHub repositories as a kanban board and lets you triage them by priority.",
  "homepage": "https://github.com/davidsneighbour/project-dashboard#readme",
  "bugs": {
    "url": "https://github.com/davidsneighbour/project-dashboard/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidsneighbour/project-dashboard.git"
  },
  "license": "MIT",
  "author": "Patrick Kollitsch <davidsneighbourdev+gh@gmail.com>",
  "type": "module",
  "main": "index.js",
  "bin": {
    "repo-triage": "cli/repo-triage.mjs"
  },
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names server,client --prefix-colors blue,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "server": "npm --prefix server run dev",
    "cli": "node cli/repo-triage.mjs",
    "test": "npm run test:client && npm run test:server && npm run test:cli",
    "test:client": "npm --prefix client run test",
    "test:server": "npm --prefix server run test",
    "test:cli": "npm --prefix cli run test",
    "test:coverage": "npm run test:coverage:client && npm run test:coverage:server && npm run test:coverage:cli",
    "test:coverage:client": "npm --prefix client run test:coverage",
    "test:coverage:server": "npm --prefix server run test:coverage",
    "test:coverage:cli": "npm --prefix cli run test:coverage",
    "test:e2e": "npm --prefix e2e run test",
    "test:e2e:ui": "npm --prefix e2e run test:ui",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "docs:api": "jsdoc -c jsdoc.config.json",
    "lint:markdown": "markdownlint-cli2 --config ./node_modules/@dnbhq/markdownlint-config/.markdownlint-cli2.jsonc \"**/*.{md,mdx}\"",
    "lint:markdown:fix": "markdownlint-cli2 --config ./node_modules/@dnbhq/markdownlint-config/.markdownlint-cli2.jsonc --fix \"**/*.{md,mdx}\"",
    "lint:markdown:single": "markdownlint-cli2 --config ./node_modules/@dnbhq/markdownlint-config/.markdownlint-cli2.jsonc"
  },
  "dependencies": {
    "@dnbhq/markdownlint-config": "0.2.7"
  },
  "devDependencies": {
    "@dnbhq/release-config": "1.0.1",
    "@release-it/conventional-changelog": "11.0.1",
    "clean-jsdoc-theme": "4.3.2",
    "concurrently": "10.0.3",
    "jsdoc": "4.0.5",
    "release-it": "20.2.0"
  },
  "cspell": {
    "version": "0.2",
    "language": "en-GB",
    "dictionaryDefinitions": [
      {
        "name": "project-words",
        "path": ".vscode/dictionary.txt",
        "addWords": true
      }
    ],
    "dictionaries": [
      "project-words"
    ],
    "ignorePaths": [
      "**/node_modules/**",
      "**/dist/**",
      "**/coverage/**",
      "**/.git/**",
      "**/*.lock",
      "**/package-lock.json",
      "**/*.min.js",
      "client/src/help-diagram.svg",
      ".vscode/dictionary.txt"
    ]
  }
}

# Recommended: keep your token in ~/.env and start with:
#   docker compose --env-file ~/.env up --build
#
# Or copy this file to .env in the project root.

# Required. Classic token needs the `repo` scope to read PRIVATE repos.
# A fine-grained token needs read access to repository metadata.
GITHUB_TOKEN=ghp_your_token_here

# Optional. Leave blank to load YOUR full repo set (public + private + archived).
# If set, loads that user/org's PUBLIC repos only.
GITHUB_USERNAME=

# Days a P1–P3 repo stays put before auto-degrading to "Look again".
# Can be overridden per repository in the UI.
DEFAULT_INACTIVITY_DAYS=7

{
  "name": "repo-dashboard-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=26.0.0"
  },
  "scripts": {
    "start": "node --env-file-if-exists=../.env --import ./instrument.js index.js",
    "dev": "node --env-file-if-exists=../.env --import ./instrument.js --watch index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@sentry/node": "10.65.0",
    "better-sqlite3": "12.11.1",
    "express": "5.2.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.9",
    "supertest": "7.2.2",
    "vitest": "4.1.9"
  }
}
